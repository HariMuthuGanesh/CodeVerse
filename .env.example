# ============================================================
# CodeVerse - Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit your real .env file to version control.
#
# cp .env.example .env   (Linux/Mac)
# copy .env.example .env (Windows)
# ============================================================

# ---------------------------
# Flask Configuration
# ---------------------------

# Secret key used for session signing. Use a long random string in production.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-very-secret-random-key-here

# ---------------------------
# Supabase Configuration
# ---------------------------

# Your Supabase project URL (found in: Project Settings > API)
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Service Role Key — required for server-side DB writes
# Found in: Project Settings > API > service_role (secret)
# WARNING: Never expose this key on the client side!
SUPABASE_SERVICE_KEY=your-supabase-service-role-key-here
